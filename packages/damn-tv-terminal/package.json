{
  "name": "@damnthat/damn-tv",
  "version": "0.1.0",
  "private": true,
  "description": "Damn TV — ASCII terminal shooter for damnthat.tv.",
  "type": "module",
  "license": "ISC",
  "author": "J Scott Smith",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm build",
    "dev": "tsup --watch",
    "start": "node dist/bin.js",
    "typeCheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:ci": "oxlint --format github ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "oxlint": "^1.67.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
