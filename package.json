{
  "name": "damn-that-television",
  "version": "1.13.1",
  "description": "Damn that television. The personal website of J Scott Smith",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "typeCheck": "turbo run typeCheck",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "slicemachine": "turbo run slicemachine",
    "ui:add": "pnpm dlx shadcn@latest add --cwd apps/damnthat.tv",
    "ui:add:design-system": "pnpm dlx shadcn@latest add --cwd apps/design-system"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jscottsmith/damn-that-television.git"
  },
  "author": "J Scott Smith",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jscottsmith/damn-that-television/issues"
  },
  "homepage": "https://damnthat.tv/",
  "devDependencies": {
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "turbo": "^2.9.16"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@<11.1.1": ">=11.1.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@anthropic-ai/claude-agent-sdk>zod": "4"
      }
    }
  }
}
