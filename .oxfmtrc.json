{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "arrowParens": "always",
  "sortTailwindcss": {},
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    ".next",
    ".yarn",
    "yarn.lock",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.svg"
  ]
}
